<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@android:drawable/ic_dialog_info"
        android:theme="@style/Theme.TimerWidget">

        <!-- Timer Widget Provider -->
        <receiver
            android:name=".TimerWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.timers.widget.ACTION_TIMER_TICK" />
                <action android:name="com.timers.widget.ACTION_TIMER_START" />
                <action android:name="com.timers.widget.ACTION_TIMER_STOP" />
                <action android:name="com.timers.widget.ACTION_TIMER_EDIT" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/timer_widget_info" />
        </receiver>

        <!-- Timer Service -->
        <service
            android:name=".TimerService"
            android:exported="false" />

        <!-- Widget Configuration Activity -->
        <activity
            android:name=".TimerConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.TimerWidget.Dialog">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ResetConfirmActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:theme="@style/Theme.TimerWidget.Dialog" />

    </application>

</manifest>
