<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/home_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/home_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/home_message"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/backup_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/backup_status_not_connected"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_connect_backup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/backup_connect"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_backup_now"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/backup_now"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_restore_latest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/restore_latest"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_disable_backup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/backup_disable" />

</LinearLayout>
